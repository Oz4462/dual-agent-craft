{
  "_comment": "Merged into ~/.claude/settings.json (or project .claude/settings.json) by harness/install.sh. Deny wins over allow; ask prompts every time.",
  "permissions": {
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*main*)",
      "Bash(git push --force*master*)",
      "Bash(chmod -R 777*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.pem)",
      "Write(.env)",
      "Write(**/*.pem)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(gh pr merge*)",
      "Bash(npm publish*)",
      "Bash(pip install *)",
      "Bash(npm install -g*)"
    ],
    "allow": [
      "Bash(git status*)", "Bash(git diff*)", "Bash(git log*)", "Bash(git show*)",
      "Bash(git add*)", "Bash(git commit*)", "Bash(git switch*)", "Bash(git worktree*)",
      "Bash(ls*)", "Bash(rg *)", "Bash(grep *)", "Bash(find *)", "Bash(wc *)",
      "Bash(python3 -m pytest*)", "Bash(pytest*)", "Bash(npm test*)", "Bash(bash -n *)",
      "Bash(tests/run.sh*)", "Bash(./dual-build.sh*)", "Bash(./dual-review.sh*)",
      "Bash(./dual-merge.sh*)", "Bash(./dual-tiebreak.sh*)", "Bash(./lib/*.sh*)"
    ]
  }
}
